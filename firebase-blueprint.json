{
  "entities": {
    "AdminActivity": {
      "title": "Admin Activity",
      "description": "Logs of actions performed by administrators",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user": { "type": "string" },
        "action": { "type": "string" },
        "target": { "type": "string" },
        "time": { "type": "number" }
      },
      "required": ["id", "user", "action", "target", "time"]
    },
    "User": {
      "title": "User Profile",
      "description": "User profile and progress data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "progress": {
          "type": "object",
          "properties": {
            "completedLessons": { "type": "array", "items": { "type": "string" } },
            "certificates": { "type": "array", "items": { "type": "string" } },
            "lastActiveDate": { "type": "string" },
            "status": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Skill": {
      "title": "Skill",
      "description": "A development skill or career path",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "title"]
    },
    "Module": {
      "title": "Module",
      "description": "A learning module within a skill",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "skillId": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "number" },
        "lessons": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "skillId", "title", "order"]
    },
    "Lesson": {
      "title": "Lesson Content",
      "description": "Full content of a lesson",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "object" },
        "updatedAt": { "type": "number" }
      },
      "required": ["id", "title", "updatedAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Platform-wide announcement",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "time": { "type": "number" }
      },
      "required": ["id", "title", "content", "time"]
    },
    "Report": {
      "title": "Moderation Report",
      "description": "A report filed by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporterId": { "type": "string" },
        "targetId": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string" },
        "time": { "type": "number" }
      },
      "required": ["id", "reporterId", "reason", "status", "time"]
    },
    "Settings": {
      "title": "Platform Settings",
      "description": "Global configuration for the platform",
      "type": "object",
      "properties": {
        "platformName": { "type": "string" },
        "supportEmail": { "type": "string" },
        "maintenanceMode": { "type": "boolean" },
        "twoFactorAuth": { "type": "boolean" },
        "sessionTimeout": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "admin_activity": { "schema": "AdminActivity", "description": "Logs of admin actions" },
    "users": { "schema": "User", "description": "User profiles and progress" },
    "skills": { "schema": "Skill", "description": "Available career paths" },
    "modules": { "schema": "Module", "description": "Curriculum modules" },
    "lessons": { "schema": "Lesson", "description": "Full lesson content" },
    "announcements": { "schema": "Announcement", "description": "Platform announcements" },
    "reports": { "schema": "Report", "description": "User reports for moderation" },
    "admin_settings": { "schema": "Settings", "description": "Global platform settings" }
  }
}
