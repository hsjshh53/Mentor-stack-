{
  "entities": {
    "UserProgress": {
      "title": "User Progress",
      "description": "Tracks the progress of a user in the curriculum.",
      "type": "object",
      "properties": {
        "selectedPath": { "type": "string" },
        "currentStage": { "type": "string" },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "streak": { "type": "number" },
        "lastActive": { "type": "string", "format": "date-time" },
        "completedLessons": { "type": "array", "items": { "type": "string" } },
        "completedTests": { "type": "array", "items": { "type": "string" } },
        "completedExams": { "type": "array", "items": { "type": "string" } },
        "completedProjects": { "type": "array", "items": { "type": "string" } },
        "submissions": { "type": "object" },
        "certificates": { "type": "array", "items": { "type": "string" } },
        "weakAreas": { "type": "array", "items": { "type": "string" } },
        "skills": { "type": "object" },
        "unlockedPaths": { "type": "array", "items": { "type": "string" } },
        "isPremium": { "type": "boolean" },
        "dailyGoalMinutes": { "type": "number" },
        "dailyMinutesLearned": { "type": "number" },
        "lastLessonId": { "type": "string" },
        "lastLessonTitle": { "type": "string" },
        "lastActiveDate": { "type": "string", "format": "date" },
        "followers": { "type": "array", "items": { "type": "string" } },
        "following": { "type": "array", "items": { "type": "string" } },
        "badges": { "type": "array", "items": { "type": "string" } }
      }
    },
    "GithubConnection": {
      "title": "GitHub Connection",
      "description": "User's GitHub OAuth connection details.",
      "type": "object",
      "properties": {
        "accessToken": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "connectedAt": { "type": "number" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "A user's project in the playground.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "files": { "type": "object" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "githubMetadata": { "type": "object" }
      }
    },
    "Activity": {
      "title": "Activity",
      "description": "Represents a social activity in the feed.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "type": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "object" }
      }
    },
    "Certificate": {
      "title": "Certificate",
      "description": "A certificate earned by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "pathName": { "type": "string" },
        "tier": { "type": "string" },
        "level": { "type": "string" },
        "issueDate": { "type": "string" },
        "finalScore": { "type": "number" },
        "skills": { "type": "array" },
        "projectTitle": { "type": "string" },
        "projects": { "type": "array" },
        "verificationUrl": { "type": "string" },
        "isValid": { "type": "boolean" },
        "issuedBy": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}/progress/data": {
      "schema": "UserProgress",
      "description": "User's progress in the curriculum."
    },
    "/users/{userId}/github/connection": {
      "schema": "GithubConnection",
      "description": "User's GitHub connection."
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": "Project",
      "description": "User's projects."
    },
    "/activities": {
      "schema": "Activity",
      "description": "Global activity feed."
    },
    "/certificates": {
      "schema": "Certificate",
      "description": "Global certificates for verification."
    }
  }
}
