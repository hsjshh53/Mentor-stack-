{
  "entities": {
    "UserProgress": {
      "title": "User Progress",
      "description": "Tracks the learning progress and social stats of a user.",
      "type": "object",
      "properties": {
        "selectedPath": { "type": "string" },
        "currentStage": { "type": "string" },
        "xp": { "type": "integer" },
        "level": { "type": "integer" },
        "streak": { "type": "integer" },
        "lastActive": { "type": "string", "format": "date-time" },
        "completedLessons": { "type": "array", "items": { "type": "string" } },
        "completedTests": { "type": "array", "items": { "type": "string" } },
        "completedExams": { "type": "array", "items": { "type": "string" } },
        "completedProjects": { "type": "array", "items": { "type": "string" } },
        "submissions": { "type": "object" },
        "certificates": { "type": "array", "items": { "type": "string" } },
        "weakAreas": { "type": "array", "items": { "type": "string" } },
        "skills": { "type": "object" },
        "unlockedPaths": { "type": "array", "items": { "type": "string" } },
        "isPremium": { "type": "boolean" },
        "dailyGoalMinutes": { "type": "integer" },
        "dailyMinutesLearned": { "type": "integer" },
        "lastLessonId": { "type": "string" },
        "lastLessonTitle": { "type": "string" },
        "lastActiveDate": { "type": "string" },
        "followers": { "type": "array", "items": { "type": "string" } },
        "following": { "type": "array", "items": { "type": "string" } },
        "badges": { "type": "array", "items": { "type": "string" } }
      }
    },
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "progress": { "$ref": "UserProgress" }
      }
    },
    "Activity": {
      "title": "Activity",
      "description": "Social activity feed item.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "type": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "UserProjectProgress": {
      "title": "User Project Progress",
      "description": "Tracks progress on a specific project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "status": { "type": "string" },
        "currentPhaseId": { "type": "string" },
        "completedPhases": { "type": "array", "items": { "type": "string" } },
        "completedCheckpoints": { "type": "array", "items": { "type": "string" } },
        "startedAt": { "type": "integer" },
        "updatedAt": { "type": "integer" },
        "completedAt": { "type": "integer" },
        "draft": { "type": "object" },
        "githubMetadata": { "type": "object" }
      }
    },
    "Certificate": {
      "title": "Certificate",
      "description": "A certificate earned by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "pathName": { "type": "string" },
        "tier": { "type": "string" },
        "level": { "type": "string" },
        "issueDate": { "type": "string", "format": "date-time" },
        "finalScore": { "type": "number" },
        "skills": { "type": "array", "items": { "type": "string" } },
        "projectTitle": { "type": "string" },
        "projects": { "type": "array" },
        "verificationUrl": { "type": "string" },
        "isValid": { "type": "boolean" },
        "issuedBy": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and progress."
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": "UserProjectProgress",
      "description": "User progress on specific projects."
    },
    "/users/{userId}/submissions/{projectId}": {
      "schema": "object",
      "description": "User project submissions."
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Global activity feed."
    },
    "/certificates/{certificateId}": {
      "schema": "Certificate",
      "description": "Public certificates."
    }
  }
}
