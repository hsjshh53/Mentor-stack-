{
  "rules": {
    // 🛡️ GLOBAL IDENTITY SHIELD
    ".read": false,
    ".write": false,

    // 🔒 ADMIN IDENTITY & AUTHORIZATION
    "admins": {
      ".read": "auth.uid != null",
      "$uid": {
        // Allow bootstrap admins to write their own master record
        ".write": "auth.uid != null && (auth.token.email == 'harunabilikis8@gmail.com' || auth.token.email == 'hh5217924@gmail.com' || root.child('admins').child(auth.uid).exists())"
      }
    },

    // 🎓 CURRICULUM ENGINE (Primary Learning Paths)
    "curriculum_paths": { ".read": "auth.uid != null", ".write": "root.child('admins').child(auth.uid).exists()" },
    "curriculum_stages": { ".read": "auth.uid != null", ".write": "root.child('admins').child(auth.uid).exists()" },
    "curriculum_weeks": { ".read": "auth.uid != null", ".write": "root.child('admins').child(auth.uid).exists()" },
    "curriculum_modules": { ".read": "auth.uid != null", ".write": "root.child('admins').child(auth.uid).exists()" },
    "curriculum_projects": { ".read": "auth.uid != null", ".write": "root.child('admins').child(auth.uid).exists()" },
    "curriculum": { ".read": "auth.uid != null", ".write": "root.child('admins').child(auth.uid).exists()" },
    
    // 📚 CONTENT & LESSONS
    "lessons": { ".read": "auth.uid != null", ".write": "root.child('admins').child(auth.uid).exists()" },
    "ai_generated_lessons": { ".read": "auth.uid != null", ".write": "root.child('admins').child(auth.uid).exists()" },
    "skills": { ".read": "auth.uid != null", ".write": "root.child('admins').child(auth.uid).exists()" },
    "roadmaps": { ".read": "auth.uid != null", ".write": "root.child('admins').child(auth.uid).exists()" },

    // 👤 USER SYSTEM & PROGRESS TRACKING
    "users": {
      "$uid": {
        // Users can always read/write their own identity and progress
        ".read": "auth.uid == $uid || root.child('admins').child(auth.uid).exists()",
        ".write": "auth.uid == $uid || root.child('admins').child(auth.uid).exists()",
        "progress": {
          ".write": "auth.uid == $uid || root.child('admins').child(auth.uid).exists()"
        }
      },
      // Admin-only global user list read
      ".read": "auth.uid != null && root.child('admins').child(auth.uid).exists()"
    },

    // 🤖 AI ENGINE & JOB QUEUE
    "generation_jobs_v2": {
      ".read": "auth.uid != null",
      ".write": "auth.uid != null"
    },

    // 🎫 SUPPORT & TICKETS
    "support_tickets": {
      ".indexOn": ["user_id"],
      ".read": "auth.uid != null && (root.child('admins').child(auth.uid).exists() || (query.orderByChild == 'user_id' && query.equalTo == auth.uid))",
      ".write": "auth.uid != null"
    },

    // 💳 FINANCIAL & AUDIT SYSTEM
    "payments": {
      ".indexOn": ["user_id"],
      ".read": "auth.uid != null && (root.child('admins').child(auth.uid).exists() || (query.orderByChild == 'user_id' && query.equalTo == auth.uid))",
      ".write": "auth.uid != null"
    },
    "receipts": {
      ".indexOn": ["user_id"],
      ".read": "auth.uid != null && (root.child('admins').child(auth.uid).exists() || (query.orderByChild == 'user_id' && query.equalTo == auth.uid))",
      ".write": "auth.uid != null"
    },
    "payment_audit_logs": {
      ".read": "auth.uid != null && root.child('admins').child(auth.uid).exists()",
      ".write": "auth.uid != null"
    },
    "admin_audit_logs": {
      ".read": "auth.uid != null && root.child('admins').child(auth.uid).exists()",
      ".write": "auth.uid != null"
    },
    "lesson_audit_logs": {
      ".read": "auth.uid != null && root.child('admins').child(auth.uid).exists()",
      ".write": "auth.uid != null"
    },
    "certificates": {
      ".read": "auth.uid != null",
      ".write": "root.child('admins').child(auth.uid).exists()"
    }
  }
}
